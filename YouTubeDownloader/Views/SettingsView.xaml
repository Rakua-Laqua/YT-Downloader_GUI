<UserControl x:Class="YouTubeDownloader.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:YouTubeDownloader.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="700" Margin="0,0,20,0">
            <!-- 外部ツール設定 -->
            <TextBlock Text="外部ツール" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>

            <Border Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel>
                    <!-- yt-dlp パス -->
                    <StackPanel Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="yt-dlp 実行ファイルパス" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsYtDlpValid}" Value="True">
                                                    <Setter Property="Fill" Value="Green"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="見つかりません"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsYtDlpValid}" Value="True">
                                                    <Setter Property="Text" Value="OK"/>
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding YtDlpAutoDetected}" Foreground="#666" FontSize="12" Margin="0,5,0,5"/>
                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding YtDlpPath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"/>
                            <Button Grid.Column="1" Content="参照..."
                                    Command="{Binding BrowseYtDlpPathCommand}"
                                    Padding="15,8" Margin="10,0,0,0"/>
                        </Grid>
                        <TextBlock Text="※ 空欄の場合は自動検出されたパスを使用します"
                                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <CheckBox Content="yt-dlpを初回利用前に自動更新する"
                                          IsChecked="{Binding AutoUpdateYtDlp}"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding YtDlpUpdateStatus}"
                                           Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Content="今すぐ更新"
                                    Command="{Binding UpdateYtDlpCommand}"
                                    Padding="15,8" Margin="10,0,0,0"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- ffmpeg パス -->
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ffmpeg 実行ファイルパス" FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="Red"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFfmpegValid}" Value="True">
                                                    <Setter Property="Fill" Value="Green"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="見つかりません"/>
                                            <Setter Property="Foreground" Value="Red"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFfmpegValid}" Value="True">
                                                    <Setter Property="Text" Value="OK"/>
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{Binding FfmpegAutoDetected}" Foreground="#666" FontSize="12" Margin="0,5,0,5"/>
                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"/>
                            <Button Grid.Column="1" Content="参照..."
                                    Command="{Binding BrowseFfmpegPathCommand}"
                                    Padding="15,8" Margin="10,0,0,0"/>
                        </Grid>
                        <TextBlock Text="※ 空欄の場合は自動検出されたパスを使用します"
                                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ダウンロード設定 -->
            <TextBlock Text="ダウンロード設定" FontSize="18" FontWeight="SemiBold" Margin="0,10,0,15"/>

            <Border Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,0,0,20">
                <StackPanel>
                    <!-- デフォルト保存先 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="デフォルト保存先フォルダ" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding DefaultSaveFolder, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="10,8"/>
                            <Button Grid.Column="1" Content="参照..."
                                    Command="{Binding BrowseDefaultSaveFolderCommand}"
                                    Padding="15,8" Margin="10,0,0,0"/>
                        </Grid>
                    </StackPanel>

                    <!-- タイトル取得言語 -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="タイトル取得言語" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ComboBox ItemsSource="{Binding MetadataLanguages}"
                                  Text="{Binding DefaultMetadataLanguage, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Padding="10,8"
                                  MinWidth="180"
                                  HorizontalAlignment="Left"/>
                        <TextBlock Text="例: ja / en / default。変更後に解析し直すと反映されます。"
                                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- フォーマット設定 -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="デフォルト動画フォーマット" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding VideoFormats}"
                                      SelectedItem="{Binding DefaultVideoFormat}"
                                      Padding="10,8"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5,0">
                            <TextBlock Text="デフォルト音声フォーマット" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AudioFormats}"
                                      SelectedItem="{Binding DefaultAudioFormat}"
                                      Padding="10,8"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="デフォルト品質" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Qualities}"
                                      SelectedItem="{Binding DefaultQuality}"
                                      Padding="10,8"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="10,12,0,0">
                            <TextBlock Text="デフォルト音声品質" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding AudioQualities}"
                                      SelectedItem="{Binding DefaultAudioQuality}"
                                      Padding="10,8"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Margin="0,0,0,20">
                        <CheckBox Content="mp4でも画質優先コーデック（AV1）を使う"
                                  IsChecked="{Binding PreferHighEfficiencyCodecs}"/>
                        <TextBlock Text="ONにするとmp4保存時もAV1を優先します。古い端末や一部編集ソフトでは再生できない場合があります。"
                                   Foreground="Gray" FontSize="11" Margin="0,5,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- ファイル名テンプレート -->
                    <StackPanel>
                        <TextBlock Text="ファイル名テンプレート" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBox Text="{Binding FilenameTemplate, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="10,8"/>
                        <TextBlock Margin="0,8,0,0" Foreground="Gray" FontSize="11">
                            <Run Text="使用可能なプレースホルダ: "/>
                            <Run Text="{}{title}" FontWeight="SemiBold"/>
                            <Run Text=" - 動画タイトル、"/>
                            <Run Text="{}{channel}" FontWeight="SemiBold"/>
                            <Run Text=" - チャンネル名、"/>
                            <Run Text="{}{id}" FontWeight="SemiBold"/>
                            <Run Text=" - 動画ID、"/>
                            <Run Text="{}{index}" FontWeight="SemiBold"/>
                            <Run Text=" - プレイリストインデックス"/>
                        </TextBlock>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="プレビュー: " Foreground="Gray"/>
                            <TextBlock Text="{Binding FilenamePreview}" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 保存ボタン -->
            <Button Content="設定を保存"
                    Command="{Binding SaveSettingsCommand}"
                    HorizontalAlignment="Right"
                    Padding="30,12"
                    FontSize="14" FontWeight="SemiBold"
                    Background="#4CAF50" Foreground="White"
                    BorderThickness="0" Cursor="Hand"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
