<UserControl x:Class="YouTubeDownloader.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:YouTubeDownloader.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="900"
             d:DataContext="{d:DesignInstance Type=vm:DownloadViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="0,0,10,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- URL入力セクション -->
        <Border Grid.Row="0" Background="#F5F5F5" Padding="20" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="動画/プレイリストURL" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" 
                             Text="{Binding InputUrl, UpdateSourceTrigger=PropertyChanged}"
                             Padding="12,10" FontSize="14"
                             VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" 
                            Content="解析" 
                            Command="{Binding AnalyzeCommand}"
                            Padding="25,10" Margin="10,0,0,0"
                            FontSize="14" FontWeight="SemiBold"
                            Background="#FF4444" Foreground="White"
                            BorderThickness="0" Cursor="Hand"/>
                </Grid>

                <!-- ローディング表示 -->
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"
                            Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="解析中..." FontStyle="Italic" Foreground="Gray"/>
                </StackPanel>

                <!-- 解析結果 -->
                <Border Visibility="{Binding HasAnalyzedResult, Converter={StaticResource BoolToVis}}"
                        Background="White" Padding="15" Margin="0,15,0,0" CornerRadius="5"
                        BorderBrush="#DDD" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- サムネイル -->
                        <Border Grid.Column="0" CornerRadius="5" ClipToBounds="True"
                                Background="#EEE" Width="150" Height="85">
                            <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                        </Border>

                        <!-- 情報 -->
                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="{Binding VideoTitle}" FontSize="16" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ChannelName}" Foreground="Gray" Margin="0,5,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Border Background="{Binding IsPlaylist, Converter={StaticResource BoolToVis}, ConverterParameter=#E3F2FD}"
                                        Padding="8,4" CornerRadius="3">
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="単一動画"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlaylist}" Value="True">
                                                        <Setter Property="Text" Value="プレイリスト"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Duration}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPlaylist}" Value="True">
                                                    <Setter Property="Text" Value="{Binding VideoCount, StringFormat={}{0} 本の動画}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 取得漏れ警告 -->
                <Border Visibility="{Binding IsPlaylistTruncated, Converter={StaticResource BoolToVis}}"
                        Background="#FFF8E1" BorderBrush="#FFD54F" BorderThickness="1"
                        CornerRadius="6" Padding="12,10" Margin="0,10,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x26A0;" FontSize="16" Foreground="#F9A825"
                                   VerticalAlignment="Top" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding TruncationWarningText}"
                                   Foreground="#8D6E00" TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- プレイリストアイテム選択 -->
                <Border Visibility="{Binding IsPlaylist, Converter={StaticResource BoolToVis}}"
                        Margin="0,10,0,0">
                    <Expander Header="動画を選択" IsExpanded="True">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,10">
                                <Button Content="すべて選択" Command="{Binding SelectAllPlaylistItemsCommand}"
                                        Padding="10,5" Margin="0,0,10,0"/>
                                <Button Content="すべて解除" Command="{Binding ClearAllPlaylistItemsCommand}"
                                        Padding="10,5"/>
                            </StackPanel>
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding PlaylistItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="5" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="35"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Index}"
                                                               Foreground="Gray" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Title}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Duration}"
                                                               Foreground="Gray" VerticalAlignment="Center"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Expander>
                </Border>

                <!-- ダウンロード設定 -->
                <Border Visibility="{Binding HasAnalyzedResult, Converter={StaticResource BoolToVis}}"
                        Background="#FAFAFA" Padding="15" Margin="0,15,0,0" CornerRadius="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 保存先 -->
                        <StackPanel Grid.Column="0" Grid.ColumnSpan="3" Margin="0,0,0,15">
                            <TextBlock Text="保存先フォルダ" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SaveFolderPath}" 
                                         Padding="8,6" IsReadOnly="True"/>
                                <Button Grid.Column="1" Content="参照..."
                                        Command="{Binding BrowseSaveFolderCommand}"
                                        Padding="15,6" Margin="8,0,0,0"/>
                            </Grid>
                        </StackPanel>

                        <!-- ダウンロード種別 -->
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="ダウンロード種別" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton Content="動画＋音声" 
                                             IsChecked="{Binding IsAudioOnly, Converter={StaticResource InverseBoolConverter}}"
                                             GroupName="DownloadType"
                                             VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <RadioButton Content="音声のみ" 
                                             IsChecked="{Binding IsAudioOnly}"
                                             GroupName="DownloadType"
                                             VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- フォーマット -->
                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="5,0">
                            <TextBlock Text="フォーマット" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding CurrentFormats}"
                                      SelectedItem="{Binding SelectedFormat}"
                                      Padding="8,6"/>
                        </StackPanel>

                        <!-- 品質 -->
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="5,0,0,0">
                            <TextBlock Text="品質" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <ComboBox ItemsSource="{Binding CurrentQualities}"
                                      SelectedItem="{Binding SelectedQuality}"
                                      Padding="8,6"/>
                        </StackPanel>

                        <!-- ダウンロードボタン -->
                        <StackPanel Grid.Row="2" Grid.ColumnSpan="3" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="ダウンロード開始"
                                    Command="{Binding StartDownloadCommand}"
                                    Padding="20,10"
                                    FontWeight="SemiBold"
                                    Background="#4CAF50" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <!-- ダウンロードキュー -->
        <Grid Grid.Row="1" Margin="0,10,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="ダウンロードキュー" FontSize="16" FontWeight="SemiBold"/>
            <TextBlock Grid.Column="1" Text="{Binding DownloadQueueSummaryText}"
                       Foreground="Gray" FontSize="13" VerticalAlignment="Bottom"/>
        </Grid>

        <Border Grid.Row="2" Background="#F5F5F5" Padding="10" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                    <Button Content="全キャンセル"
                        Command="{Binding CancelAllJobsCommand}"
                        Padding="10,5" Margin="0,0,10,0"/>
                    <Button Content="キューを全削除"
                        Command="{Binding ClearAllJobsCommand}"
                        Padding="10,5" Margin="0,0,10,0"/>
                    <Button Content="完了済みをクリア"
                        Command="{Binding ClearCompletedJobsCommand}"
                        Padding="10,5"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding DownloadQueue}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" Padding="15" Margin="0,0,0,8" CornerRadius="5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- サムネイル -->
                                        <Border Grid.Column="0" CornerRadius="3" ClipToBounds="True"
                                                Background="#EEE" Width="70" Height="40">
                                            <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"/>
                                        </Border>

                                        <!-- 情報 -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="10,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="Blue" TextDecorations="Underline" Cursor="Hand"
                                                       ToolTip="{Binding Url}">
                                                <TextBlock.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.OpenVideoLinkCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </TextBlock.InputBindings>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="12"
                                                           TextWrapping="Wrap"
                                                           ToolTip="{Binding StatusText}"/>
                                                <!-- 完了時の詳細情報。所要時間・保存先・フォーマット検証結果を表示する -->
                                                <Border Width="18" Height="18" Margin="4,0,0,0"
                                                        Background="Transparent" Cursor="Help"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding HasCompletionInfo, Converter={StaticResource BoolToVis}}"
                                                        ToolTipService.InitialShowDelay="0"
                                                        ToolTipService.ShowDuration="60000">
                                                    <Border.ToolTip>
                                                        <ToolTip Placement="Mouse" MaxWidth="560">
                                                            <TextBlock Text="{Binding CompletionInfoTooltip}"
                                                                       TextWrapping="Wrap"/>
                                                        </ToolTip>
                                                    </Border.ToolTip>
                                                    <TextBlock Text="ⓘ" FontSize="13" Foreground="#1976D2"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <!-- フォーマット不一致警告。ホバーで差異の詳細を表示する -->
                                                <TextBlock Text="⚠" FontSize="14" Foreground="#F9A825" Margin="4,0,0,0"
                                                           VerticalAlignment="Center" Cursor="Help"
                                                           Visibility="{Binding HasFormatMismatch, Converter={StaticResource BoolToVis}}"
                                                           ToolTip="{Binding FormatMismatchTooltip}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- 進捗 (変換などの後処理中は不確定アニメで「処理中」を示す) -->
                                        <ProgressBar Grid.Column="1" Grid.Row="1" Margin="10,6,10,0"
                                                     Value="{Binding Progress}" Maximum="100" Height="6"
                                                     IsIndeterminate="{Binding IsPostProcessing}"/>

                                        <!-- ボタン -->
                                        <StackPanel Grid.Column="2" Grid.RowSpan="2"
                                                Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                Margin="10,0,0,0">
                                            <Button Content="キャンセル"
                                                Command="{Binding CancelCommand}"
                                                Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"
                                                MinWidth="100" Padding="10,5"/>
                                            <Button Content="リトライ"
                                                Command="{Binding RetryCommand}"
                                                Visibility="{Binding CanRetry, Converter={StaticResource BoolToVis}}"
                                                MinWidth="100" Padding="10,5"/>
                                            <Button Content="失敗詳細をコピー"
                                                Command="{Binding CopyFailureDetailCommand}"
                                                Visibility="{Binding HasFailureDetail, Converter={StaticResource BoolToVis}}"
                                                ToolTip="失敗フェーズ・終了コード・stderr全文などをクリップボードへコピーします"
                                                MinWidth="100" Padding="10,5" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- 空の状態 -->
                <TextBlock Grid.Row="1"
                           Text="ダウンロードキューは空です"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding DownloadQueue.Count, Converter={StaticResource BoolToVis}, ConverterParameter=Inverted}"/>
            </Grid>
        </Border>
    </Grid>
    </ScrollViewer>
</UserControl>
